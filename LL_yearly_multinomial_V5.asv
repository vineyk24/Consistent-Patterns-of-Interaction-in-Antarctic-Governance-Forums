%% ================================================================
%  Choose dataset: 'ATCM' or 'CCAMLR'  (reads Excel .xlsx with columns: Year, Authors)
%    ATCM_WP_Authors.xlsx
%    CCAMLR_Authors.xlsx
% ================================================================
clear all

dataset = 'CCAMLR';  % <-- set to 'ATCM' or 'CCAMLR'
%dataset = 'ATCM';    % <-- set to 'ATCM' or 'CCAMLR'
doAnalyses = 1;

if doAnalyses == 1
    switch upper(dataset)
        case 'ATCM'
            infile = 'ATCM_WP_Authors.xlsx';
        case 'CCAMLR'
            infile = 'CCAMLR_Authors.xlsx';
        otherwise
            error('dataset must be ''ATCM'' or ''CCAMLR''');
    end

    % ---------- Robust Excel read (xlsread raw parsing; no TextType needed) ----------
    [~,~,raw] = xlsread(infile);   % raw cell array (includes header row)
    if size(raw,2) < 2
        error('Expected at least two columns (Year, Authors) in %s.', infile);
    end

    % Detect header row: if first row, col1 is non-numeric or col2 is not char
    isHeader = false;
    if ~isempty(raw)
        c1 = raw{1,1};
        c2 = raw{1,2};
        if ~(isnumeric(c1) || (ischar(c1) && ~isnan(str2double(c1)))) || ~ischar(c2)
            isHeader = true;
        end
    end

    data = raw(1+isHeader:end, 1:2);  % [Year, Authors] rows (no header)
    % Year: allow numeric or numeric-string
    Year_wp = nan(size(data,1),1);
    for r = 1:size(data,1)
        yr = data{r,1};
        if isnumeric(yr), Year_wp(r) = yr;
        elseif ischar(yr), Year_wp(r) = str2double(yr);
        else, Year_wp(r) = NaN;
        end
    end
    % Authors: char only; coauthors separated by commas
    Author_wp = data(:,2);
    Author_wp = cellfun(@(s) ifelse(ischar(s), s, ''), Author_wp, 'uni', false);

    % Drop rows with missing year or empty author cell
    if strcmp(dataset,'CCAMLR') == 1
        keep = ~isnan(Year_wp) & ~cellfun(@isempty, Author_wp) & Year_wp < 2021;
    else
        keep = ~isnan(Year_wp) & ~cellfun(@isempty, Author_wp);
    end
    Year_wp   = Year_wp(keep); Author_wp = Author_wp(keep);

    % ---------- Eligibility maps ----------
    switch upper(dataset)
        case 'ATCM'
            countries = { ...
                'Argentina','Australia','Belgium','Brazil','Bulgaria','Canada','Chile','China', ...
                'Colombia','Czechia','Ecuador','Finland','France','Germany','Greece','India', ...
                'Italy','Japan','Korea (ROK)','Malaysia','Monaco','Netherlands','New Zealand','Norway', ...
                'Peru','Poland','Romania','Russian Federation','San Marino','Saudi Arabia','Slovakia','Slovenia', ...
                'South Africa','Spain','Sweden','Switzerland','Türkiye','Ukraine','United Kingdom', ...
                'United States','Uruguay','Venezuela', ...
                'SCAR','COMNAP','CCAMLR','IPY-IPO','IHO','IAATO','WMO','ASOC','Portugal','Estonia'};
            eligibility_year = [ ...
                1961,1961,1961,1975,1978,1988,1961,1985, ...
                2020,2014,1990,1989,1961,1981,1968,1983, ...
                1987,1961,1987,2016,2009,1990,1961,1961, ...
                1989,1977,2003,1961,2023,2024,1993,2019, ...
                1961,1988,1988,1990,1996,1992,1961, ...
                1961,1985,1999, ...
                1987,1991,1991,2006,2008,1994,2013,1991,2010,2001];
            eligibilityYearMap = containers.Map(countries, num2cell(eligibility_year));

        case 'CCAMLR'
            ccamlr_countries = { ...
                'Argentina','Australia','Belgium','Brazil','Bulgaria','Canada','Chile','European Union', ...
                'Finland','France','Germany','Greece','India','Italy','Japan','Namibia','Netherlands', ...
                'New Zealand','Norway','Peru','Poland','Korea (ROK)','Russian Federation', ...
                'South Africa','Spain','Sweden','Ukraine','United Kingdom','United States','Uruguay','Vanuatu','China'};
            ccamlr_year = [ ...
                1982,1982,1984,1986,1992,1988,1982,1982, ...
                1989,1982,1983,1987,1985,1989,1982,2000,1990, ...
                1982,1984,1989,1984,1985,1982, ...
                1982,1984,1984,2000,1982,1982,1985,2001,2007];
            eligibilityYearMap = containers.Map(ccamlr_countries, num2cell(ccamlr_year));
    end

    % ---------- ORIGINALS YEAR ----------
    if strcmpi(dataset,'ATCM')
        originalYear = 1961;
    elseif strcmpi(dataset,'CCAMLR')
        originalYear = 1982;
    else
        error('dataset must be ATCM or CCAMLR');
    end

    % ===================== GRIDS (dataset-specific) =====================
    switch upper(dataset)
        case 'ATCM'
            G = 40;
            % Initial δ grids in [1,4]
            delta1_grid = linspace(1, 4, G);                 % Model 1 (linear)
            delta_grid  = linspace(1, 4, round(G/2));        % Model 2 (δ + exponent)
            exp_grid    = linspace(0.5, 1, round(G/2));

            % Models 3a/3b
            delta1_grid2 = linspace(1, 4, round(G/2));       % δ1 grid
            delta2_grid2 = linspace(1, 4, round(G/2));       % δ2 grid
            exp_grid2    = linspace(0.5, 1, round(G/2));     % shared λ (Model 3a)
            exp1_grid2   = linspace(0.5, 1, round(G/2));     % λ1 (OO)   (Model 3b)
            exp2_grid2   = linspace(0.5, 1, round(G/2));     % λ2 (other) (Model 3b)

            % Edge-zoom bounds for δ
            minDelta = 1.0;  maxDelta = 4.0;

        case 'CCAMLR'
            G = 40;
            % CCAMLR uses larger δs (per your past fits)
            delta1_grid = linspace(1.5, 5.0, G);             % Model 1 (linear)
            delta_grid  = linspace(5, 6.5, round(G/2));      % Model 2 (δ + exponent)
            exp_grid    = linspace(0.25, 1, round(G/2));

            % Models 3a/3b (δ1, δ2 in ~[5,7])
            delta1_grid2 = linspace(5, 7, round(G/2));
            delta2_grid2 = linspace(5, 7, round(G/2));
            exp_grid2    = linspace(0.5, 1.5, round(G/2));   % shared λ (Model 3a)
            exp1_grid2   = linspace(0.5, 1.5, round(G/2));   % λ1 (OO)   (Model 3b)
            exp2_grid2   = linspace(0.5, 1.5, round(G/2));   % λ2 (other) (Model 3b)

            % Edge-zoom bounds for δ (wider than initial grids)
            minDelta = 4.0;  maxDelta = 8.0;
    end

    % ===================== PRECOMPUTE ONCE (FAST PATH) =====================
    pre = build_precomputed_dataset_fast(Author_wp, Year_wp, eligibilityYearMap, originalYear);
    
    % ===================== MODEL 1: Linear (exponent = 1), single δ =====================
    logL_lin = zeros(numel(delta1_grid),1);
    for i = 1:numel(delta1_grid)
        params = struct('delta1', delta1_grid(i), 'delta2', delta1_grid(i), 'exponent', 1);
        logL_lin(i) = loglik_twoDelta_fast(pre, params, false);
    end
    [logL_lin_max, idx_lin_max] = max(logL_lin);

    % ===================== MODEL 2: Single δ + exponent (with edge zoom) =====================
    [bestVal_single, best_delta_eq, best_exponent_single, logL_single, ...
        delta_grid, exp_grid] = search_model2_with_zoom(pre, delta_grid, exp_grid, minDelta, maxDelta, 0.1, 2.0);

    % ===================== MODEL 3a: Two δ + shared λ (3-D) with edge zoom =====================
    [bestVal_two3D_shared, best_delta1_shared, best_delta2_shared, best_lambda_shared, ...
        logL_two_shared_surface, delta1_grid2_s, delta2_grid2_s, exp_grid2_s] = ...
        search_model3a_with_zoom(pre, delta1_grid2, delta2_grid2, exp_grid2, minDelta, maxDelta, 0.1, 2.0);

    % ===================== MODEL 3b: Two δ + two λ (4-D) with edge zoom =====================
    [bestVal_two4D, best_delta1, best_delta2, best_lambda1_two, best_lambda2_two, ...
        logL_two, delta1_grid2, delta2_grid2, exp1_grid2, exp2_grid2] = ...
        search_model3b_with_zoom(pre, delta1_grid2, delta2_grid2, exp1_grid2, exp2_grid2, minDelta, maxDelta, 0.1, 2.0);

    % Save everything (simple)
    eval(['save Fitting_results_' dataset])
else
    % -------- load previous results --------
    eval(['load Fitting_results_' dataset ' logL* delta* idx_lin_max exp_grid exp* best* *_wp eligibilityYearMap originalYear pre'])

    % If precompute is missing, rebuild
    if ~exist('pre','var')
        pre = build_precomputed_dataset_fast(Author_wp, Year_wp, eligibilityYearMap, originalYear);
    end

    % Set bounds according to dataset (for any plotting/extra searches later)
    switch upper(dataset)
        case 'ATCM',   minDelta = 1.0; maxDelta = 4.0;
        case 'CCAMLR', minDelta = 4.0; maxDelta = 8.0;
    end
end

% ===================== FIGURES =====================
figure(1); clf

% (1,3,1) Linear cross-section
subplot(1,3,1)
plot(delta1_grid, logL_lin, 'LineWidth', 2); grid on
hold on
plot(delta1_grid(idx_lin_max), logL_lin_max, 'bo', 'MarkerFaceColor','b')
hold off
xlabel('$\delta$'), ylabel('log-likelihood')
title(sprintf('Model 1 (%s): Linear, single delta', upper(dataset)))

% (1,3,2) Single-δ + exponent surface
subplot(1,3,2)
[DD, EE] = meshgrid(delta_grid, exp_grid);
pc = pcolor(DD, EE, logL_single'); set(pc,'edgecolor','none')
colormap parula; colorbar
hold on
plot(best_delta_eq, best_exponent_single, 'ko', 'MarkerFaceColor','w', 'MarkerSize',6)
hold off
xlabel('$\delta$'), ylabel('$\lambda$')
title(sprintf('Model 2 (%s): single delta + exponent', upper(dataset)))

% (1,3,3) Two-δ surface at best (λ1, λ2) for Model 3b
subplot(1,3,3)
[DD1, DD2] = meshgrid(delta1_grid2, delta2_grid2);
pc2 = pcolor(DD1, DD2, logL_two'); set(pc2,'edgecolor','none')
colormap parula; colorbar
hold on
plot(best_delta1, best_delta2, 'ks', 'MarkerFaceColor','w', 'MarkerSize',6)
hold off
xlabel('$\delta_1$'), ylabel('$\delta_2$')
title(sprintf('Model 3b (%s): two deltas (\\lambda_1 = %.3f, \\lambda_2 = %.3f)', ...
      upper(dataset), best_lambda1_two, best_lambda2_two))

% ===================== MODEL 0: Null (delta = 0) =====================
null_params = struct('delta1', 0, 'delta2', 0, 'exponent', 1);
logL_null = loglik_twoDelta_fast(pre, null_params, false);

% ===================== AIC COMPARISON (correct k) =====================
LL0  = logL_null;                k0  = 0;
LL1  = logL_lin_max;             k1  = 1;
LL2  = bestVal_single;           k2  = 2;
LL3a = bestVal_two3D_shared;     k3a = 3;   % (δ1, δ2, λ)
LL3b = bestVal_two4D;            k3b = 4;   % (δ1, δ2, λ1, λ2)

AIC0  = 2*k0  - 2*LL0;
AIC1  = 2*k1  - 2*LL1;
AIC2  = 2*k2  - 2*LL2;
AIC3a = 2*k3a - 2*LL3a;
AIC3b = 2*k3b - 2*LL3b;

fprintf('\n=== %s | Likelihood & AIC Summary ===\n', upper(dataset));
fprintf('Model 0 (Null):           logL = %.6f,  AIC = %.6f\n', LL0, AIC0);
fprintf('Model 1 (Linear):         MLE delta = %.6f | logL = %.6f, AIC = %.6f\n', delta1_grid(idx_lin_max), LL1, AIC1);
fprintf('Model 2 (δ+λ):            MLE delta = %.6f, λ = %.6f | logL = %.6f, AIC = %.6f\n', best_delta_eq, best_exponent_single, LL2, AIC2);
fprintf('Model 3a (δ1,δ2,λ):       MLE δ1 = %.6f, δ2 = %.6f, λ = %.6f | logL = %.6f, AIC = %.6f\n', best_delta1_shared, best_delta2_shared, best_lambda_shared, LL3a, AIC3a);
fprintf('Model 3b (δ1,δ2,λ1,λ2):   MLE δ1 = %.6f, δ2 = %.6f, λ1 = %.6f, λ2 = %.6f | logL = %.6f, AIC = %.6f\n', best_delta1, best_delta2, best_lambda1_two, best_lambda2_two, LL3b, AIC3b);

AICs = [AIC0 AIC1 AIC2 AIC3a AIC3b];
dAIC = AICs - min(AICs);
w = exp(-0.5*dAIC); w = w/sum(w);
labels = {'Null','Linear','Single δ','Two δ (shared λ)','Two δ (λ1,λ2)'};
fprintf('\n=== AIC Weights ===\n')
for m = 1:numel(labels)
    fprintf('  %-18s  ΔAIC = %7.3f   weight = %.3f\n', labels{m}, dAIC(m), w(m));
end

% ---------- Per-year AIC weights (stacked bars), using best-fit params ----------
[~, ll_y0, yrs] = loglik_twoDelta_fast(pre, struct('delta1',0,'delta2',0,'exponent',1), true);
[~, ll_y1, ~  ] = loglik_twoDelta_fast(pre, struct('delta1',delta1_grid(idx_lin_max),'delta2',delta1_grid(idx_lin_max),'exponent',1), true);
[~, ll_y2, ~  ] = loglik_twoDelta_fast(pre, struct('delta1',best_delta_eq,'delta2',best_delta_eq,'exponent',best_exponent_single), true);
[~, ll_y3a, ~ ] = loglik_twoDelta_fast(pre, struct('delta1',best_delta1_shared,'delta2',best_delta2_shared,'exponent',best_lambda_shared), true);
[~, ll_y3b, ~ ] = loglik_twoDelta_fast(pre, struct('delta1',best_delta1,'delta2',best_delta2,'lambda1',best_lambda1_two,'lambda2',best_lambda2_two), true);

LL_year = [ll_y0 ll_y1 ll_y2 ll_y3a ll_y3b];
k_vec   = [0 1 2 3 4];
AIC_y   = 2*(k_vec) - 2*LL_year;
dAIC_y  = AIC_y - min(AIC_y, [], 2);
w_y     = exp(-0.5*dAIC_y); w_y = w_y./sum(w_y,2);

figure(2); clf
hb = bar(w_y, 1.0,'stacked'); grid on
hb(1).FaceColor = [0 0 0];
hb(2).FaceColor = [0 0.447 0.741];
hb(3).FaceColor = [0.85 0.325 0.098];
hb(4).FaceColor = [0.466 0.674 0.188];
hb(5).FaceColor = [0.494 0.184 0.556];
ylim([0 1]); ylabel('AIC weight'); xlabel('Meeting number')
title(sprintf('%s: per-year AIC weights (sum to 1)', upper(dataset)))
legend(labels,'Location','eastoutside')

%% ============================= FAST CORE (precompute + evaluate) =============================
function pre = build_precomputed_dataset_fast(Author_wp, Year_wp, eligibilityMap, originalYear)
    % Parse
    [papers, id2name, ~, ~, Year_sorted] = local_buildPapers(Author_wp, Year_wp);
    eligYearById = local_eligibilityYearById(id2name, eligibilityMap);

    % Identify "original signatories"
    if nargin < 4 || isempty(originalYear)
        finiteYears = eligYearById(isfinite(eligYearById));
        originalYear = isempty(finiteYears) * inf + ~isempty(finiteYears) * min(finiteYears);
    end
    isOriginal = (eligYearById == originalYear);

    years = unique(Year_sorted, 'stable');
    [startIdx, runLen] = firstIndicesOfGroups(Year_sorted);

    N = numel(id2name);
    Y = numel(years);

    % Prealloc containers
    pre.N = N; pre.Y = Y;
    pre.years = years;
    pre.baseEdges = zeros(Y,1);
    pre.n_y       = zeros(Y,1);
    pre.gammaln_const = zeros(Y,1);
    pre.all_lin    = cell(Y,1);   % eligible upper-tri (i<j) indices into NxN
    pre.isOO_mask  = cell(Y,1);   % mask for OO among all_lin
    pre.obs        = cell(Y,1);   % struct per year: i, j, cnt, isOO

    for yix = 1:Y
        y  = years(yix);
        i0 = startIdx(yix);
        i1 = i0 + runLen(yix) - 1;

        elig = find(eligYearById <= y);
        m = numel(elig);
        if m < 2
            pre.baseEdges(yix)   = 0;
            pre.all_lin{yix}     = [];
            pre.isOO_mask{yix}   = [];
            pre.obs{yix}         = struct('i',[],'j',[],'cnt',[],'isOO',[]);
            pre.n_y(yix)         = 0;
            pre.gammaln_const(yix) = 0;
            continue
        end

        % Eligible pairs (upper-tri) as linear indices into N×N
        [ii, jj] = find(triu(true(m),1));  % indices in 'elig'
        gi = elig(ii); gj = elig(jj);      % global ids
        pre.baseEdges(yix) = numel(gi);
        pre.all_lin{yix}   = sub2ind([N,N], gi, gj);
        pre.isOO_mask{yix} = isOriginal(gi) & isOriginal(gj);

        % Observed pairs this year (coauthor edges), filtered to eligible pairs only
        pair_list = [];
        for t = i0:i1
            A = sort(papers{t}(:))';
            if numel(A) < 2, continue, end
            A = A(eligYearById(A) <= y);
            if numel(A) < 2, continue, end
            E = nchoosek(A,2);
            pair_list = [pair_list; E]; %#ok<AGROW>
        end

        if isempty(pair_list)
            pre.obs{yix}           = struct('i',[],'j',[],'cnt',[],'isOO',[]);
            pre.n_y(yix)           = 0;
            pre.gammaln_const(yix) = 0;
        else
            lin  = sub2ind([N,N], pair_list(:,1), pair_list(:,2));
            [u_lin, ~, g] = unique(lin);
            cnt = accumarray(g, 1);
            [ri, rj] = ind2sub([N,N], u_lin);
            pre.obs{yix} = struct('i',ri, 'j',rj, 'cnt',cnt, ...
                                  'isOO', isOriginal(ri) & isOriginal(rj));
            pre.n_y(yix)           = sum(cnt);
            pre.gammaln_const(yix) = gammaln(pre.n_y(yix) + 1) - sum(gammaln(cnt + 1));
        end
    end
end

function [logL, ll_year, years] = loglik_twoDelta_fast(pre, params, returnYearly)
    if nargin < 3, returnYearly = false; end
    delta1 = params.delta1;  delta2 = params.delta2;

    % Support either single exponent or two lambdas
    if isfield(params,'lambda1') && isfield(params,'lambda2')
        expo_OO    = params.lambda1;   % exponent for original–original pairs
        expo_other = params.lambda2;   % exponent for other pairs
    else
        expo       = params.exponent;
        expo_OO    = expo;
        expo_other = expo;
    end

    N = pre.N; Y = pre.Y;
    years = pre.years;

    % Running counts matrix (symmetric)
    W = sparse(N,N);

    logL = 0;
    ll_year = zeros(Y,1);

    for yix = 1:Y
        baseEdges = pre.baseEdges(yix);
        if baseEdges == 0
            ll_year(yix) = 0;  % nothing eligible this year
            continue
        end

        all_lin = pre.all_lin{yix};
        isOO    = pre.isOO_mask{yix};

        % Denominator S_y
        if isempty(all_lin)
            S = baseEdges;
        else
            w_all = full(W(all_lin));
            sumOO     = sum( (w_all(isOO)).^expo_OO );
            sumOthers = sum( (w_all(~isOO)).^expo_other );
            S = baseEdges + delta1*sumOO + delta2*sumOthers;
        end

        % Numerator contributions + combinatorial constant
        obs = pre.obs{yix};
        if ~isempty(obs.i)
            obs_lin = sub2ind([N,N], obs.i, obs.j);
            w_obs   = full(W(obs_lin));
            deltas  = delta2 * ones(size(obs.cnt));
            deltas(obs.isOO) = delta1;

            expos   = expo_other * ones(size(obs.cnt));
            expos(obs.isOO) = expo_OO;

            ll_y = pre.gammaln_const(yix) ...
                 + sum( obs.cnt .* log( 1 + deltas .* (w_obs.^expos) ) ) ...
                 - pre.n_y(yix) * log(S);

            ll_year(yix) = ll_y;
            logL = logL + ll_y;

            % Update W for next year (symmetric add)
            W = W + sparse(obs.i, obs.j, obs.cnt, N,N) + sparse(obs.j, obs.i, obs.cnt, N,N);
        else
            ll_year(yix) = 0;
        end
    end

    if ~returnYearly
        ll_year = [];
        years   = [];
    end
end

%% ============================= SEARCH HELPERS WITH EDGE-ZOOM =============================
function [bestVal, best_delta, best_lambda, logL_single, delta_grid, exp_grid] = ...
    search_model2_with_zoom(pre, delta_grid, exp_grid, minDelta, maxDelta, minExp, maxExp)
    maxIters = 3;   grow = 0.5;  % expand 50% when at edge

    for it = 1:maxIters
        logL_single = zeros(numel(delta_grid), numel(exp_grid));
        for id = 1:numel(delta_grid)
            for ie = 1:numel(exp_grid)
                params = struct('delta1', delta_grid(id), 'delta2', delta_grid(id), 'exponent', exp_grid(ie));
                logL_single(id, ie) = loglik_twoDelta_fast(pre, params, false);
            end
        end
        [bestVal, bestIdx] = max(logL_single(:));
        [best_d_idx, best_e_idx] = ind2sub(size(logL_single), bestIdx);
        best_delta  = delta_grid(best_d_idx);
        best_lambda = exp_grid(best_e_idx);

        % expand grids if the MLE is on an edge
        [delta_grid, changed1] = expand_grid_if_edge(delta_grid, best_delta,  minDelta, maxDelta, grow);
        [exp_grid,   changed2] = expand_grid_if_edge(exp_grid,   best_lambda, minExp,   maxExp,   grow);
        if ~(changed1 || changed2), break; end
    end
end

function [bestVal, best_d1, best_d2, best_lambda, logL_surface, d1_grid, d2_grid, e_grid] = ...
    search_model3a_with_zoom(pre, d1_grid, d2_grid, e_grid, minDelta, maxDelta, minExp, maxExp)
    maxIters = 3;   grow = 0.5;

    for it = 1:maxIters
        nD1 = numel(d1_grid); nD2 = numel(d2_grid); nE = numel(e_grid);
        logL_three = nan(nD1, nD2, nE);
        for i1 = 1:nD1
            for i2 = 1:nD2
                for ie = 1:nE
                    params = struct('delta1', d1_grid(i1), 'delta2', d2_grid(i2), 'exponent', e_grid(ie));
                    logL_three(i1, i2, ie) = loglik_twoDelta_fast(pre, params, false);
                end
            end
        end
        [bestVal, bestIdx] = max(logL_three(:));
        [bi1, bi2, bie] = ind2sub(size(logL_three), bestIdx);
        best_d1 = d1_grid(bi1);
        best_d2 = d2_grid(bi2);
        best_lambda = e_grid(bie);
        logL_surface = logL_three(:, :, bie);

        [d1_grid, c1] = expand_grid_if_edge(d1_grid, best_d1, minDelta, maxDelta, grow);
        [d2_grid, c2] = expand_grid_if_edge(d2_grid, best_d2, minDelta, maxDelta, grow);
        [e_grid,  c3] = expand_grid_if_edge(e_grid,  best_lambda, minExp, maxExp, grow);
        if ~(c1 || c2 || c3), break; end
    end
end

function [bestVal, best_d1, best_d2, best_l1, best_l2, logL_surface, d1_grid, d2_grid, e1_grid, e2_grid] = ...
    search_model3b_with_zoom(pre, d1_grid, d2_grid, e1_grid, e2_grid, minDelta, maxDelta, minExp, maxExp)
    maxIters = 3;   grow = 0.5;

    for it = 1:maxIters
        nD1 = numel(d1_grid); nD2 = numel(d2_grid); nE1 = numel(e1_grid); nE2 = numel(e2_grid);
        logL_four = nan(nD1, nD2, nE1, nE2);
        for i1 = 1:nD1
            for i2 = 1:nD2
                for ie1 = 1:nE1
                    for ie2 = 1:nE2
                        params = struct('delta1', d1_grid(i1), 'delta2', d2_grid(i2), ...
                                        'lambda1', e1_grid(ie1), 'lambda2', e2_grid(ie2));
                        logL_four(i1, i2, ie1, ie2) = loglik_twoDelta_fast(pre, params, false);
                    end
                end
            end
        end
        [bestVal, bestIdx] = max(logL_four(:));
        [bi1, bi2, bie1, bie2] = ind2sub(size(logL_four), bestIdx);
        best_d1 = d1_grid(bi1);
        best_d2 = d2_grid(bi2);
        best_l1 = e1_grid(bie1);
        best_l2 = e2_grid(bie2);
        logL_surface = logL_four(:, :, bie1, bie2);

        [d1_grid, c1] = expand_grid_if_edge(d1_grid, best_d1, minDelta, maxDelta, grow);
        [d2_grid, c2] = expand_grid_if_edge(d2_grid, best_d2, minDelta, maxDelta, grow);
        [e1_grid, c3] = expand_grid_if_edge(e1_grid, best_l1, minExp, maxExp, grow);
        [e2_grid, c4] = expand_grid_if_edge(e2_grid, best_l2, minExp, maxExp, grow);
        if ~(c1 || c2 || c3 || c4), break; end
    end
end

function [g, changed] = expand_grid_if_edge(g, best_val, min_limit, max_limit, grow_frac)
    % Expand linspace grid outward if best is at an endpoint.
    n = numel(g); changed = false;
    if n < 2, return; end
    span = g(end) - g(1);
    if best_val == g(1)
        new_min = max(min_limit, g(1) - grow_frac*span);
        new_max = g(end);
        if new_min < g(1)
            g = linspace(new_min, new_max, n);
            changed = true;
        end
    elseif best_val == g(end)
        new_min = g(1);
        new_max = min(max_limit, g(end) + grow_frac*span);
        if new_max > g(end)
            g = linspace(new_min, new_max, n);
            changed = true;
        end
    end
end

%% ============================= (Legacy core kept for reference) =============================
function [logL, ll_year, years] = yearMultinomialLogLik_twoDelta(Author_wp, Year_wp, params, eligibilityMap, regime, returnYearly, originalYear)
if nargin < 6, returnYearly = false; end
delta1 = params.delta1;  delta2 = params.delta2;
if isfield(params,'lambda1') && isfield(params,'lambda2')
    expo_OO    = params.lambda1;   % exponent for OO pairs
    expo_other = params.lambda2;   % exponent for other pairs
else
    expo       = params.exponent;  % backward-compatible
    expo_OO    = expo;
    expo_other = expo;
end

[papers, id2name, ~, ~, Year_sorted] = local_buildPapers(Author_wp, Year_wp);
eligYearById = local_eligibilityYearById(id2name, eligibilityMap);

if nargin < 7 || isempty(originalYear)
    finiteYears = eligYearById(isfinite(eligYearById));
    originalYear = isempty(finiteYears) * inf + ~isempty(finiteYears) * min(finiteYears);
end
isOriginal = (eligYearById == originalYear);

N = numel(id2name);
W = zeros(N,N);
logL = 0;

years = unique(Year_sorted, 'stable');
ll_year = zeros(size(years));
[startIdx, runLen] = firstIndicesOfGroups(Year_sorted);

for yix = 1:numel(years)
    y  = years(yix);
    i0 = startIdx(yix);
    i1 = i0 + runLen(yix) - 1;

    elig = find(eligYearById <= y);
    if numel(elig) < 2
        ll_year(yix) = 0; continue
    end

    C = zeros(N,N); n_y = 0;
    for t = i0:i1
        A = sort(papers{t}(:))';
        if numel(A) < 2, continue, end
        if any(eligYearById(A) > y)
            bad = A(eligYearById(A) > y);
            warning('%s paper %d in %d includes not-yet-eligible authors: %s', ...
                regime, t, y, strjoin(arrayfun(@(q) id2name{q}, bad, 'uni', false), ', '));
        end
        E = nchoosek(A,2);
        for ee = 1:size(E,1)
            i = E(ee,1); j = E(ee,2);
            if ~(eligYearById(i) <= y && eligYearById(j) <= y)
                error('Zero-probability event: (%s,%s) in %d', id2name{i}, id2name{j}, y);
            end
            C(i,j) = C(i,j) + 1; C(j,i) = C(i,j); n_y = n_y + 1;
        end
    end
    if n_y == 0, ll_year(yix)=0; continue; end

    idx = elig; m = numel(idx);
    U    = triu(true(m),1);
    Wsub = W(idx, idx);

    o       = isOriginal(idx);
    OOmask  = triu((o*o') > 0, 1);

    baseEdges = nnz(U);
    sumOO     = sum( (Wsub(OOmask)).^expo_OO );
    sumOthers = sum( (Wsub(U & ~OOmask)).^expo_other );
    S = baseEdges + delta1*sumOO + delta2*sumOthers;

    ll_y = gammaln(n_y + 1);
    [r,c,nij_vals] = find(triu(C,1));
    for k = 1:numel(nij_vals), ll_y = ll_y - gammaln(nij_vals(k) + 1); end
    for k = 1:numel(nij_vals)
        i = r(k); j = c(k);
        wij = W(i,j);
        if isOriginal(i) && isOriginal(j)
            delt = delta1;  expc = expo_OO;
        else
            delt = delta2;  expc = expo_other;
        end
        numer = 1 + delt * (wij.^expc);
        ll_y = ll_y + nij_vals(k) * (log(numer) - log(S));
    end

    ll_year(yix) = ll_y;
    logL = logL + ll_y;

    W = W + C;
end

if ~returnYearly
    ll_year = [];
    years   = [];
end
end

% -------------------------- helpers ---------------------------
function [papers, id2name, authorDict, keptIdx, Year_sorted] = local_buildPapers(Author_wp, Year_wp)
n = numel(Author_wp);  assert(n == numel(Year_wp), 'Author_wp and Year_wp must match');
splitAuthors = cell(n,1); keep = false(n,1);
for i = 1:n
    parts = strtrim(strsplit(Author_wp{i}, ','));
    parts = parts(~cellfun(@isempty, parts));
    parts = cellfun(@normalizePartyName, parts, 'uni', false);
    splitAuthors{i} = parts;
    keep(i) = numel(parts) >= 2;   % drop singles
end
keptIdx      = find(keep);
Author_wp    = Author_wp(keep);
Year_wp      = Year_wp(keep);
splitAuthors = splitAuthors(keep);

if isempty(Author_wp)
    papers = {}; id2name = {}; authorDict = containers.Map('KeyType','char','ValueType','double'); Year_sorted = []; return;
end

allAuthors  = [splitAuthors{:}];
uniqueNames = unique(allAuthors, 'stable');
ids         = num2cell(1:numel(uniqueNames));
authorDict  = containers.Map(uniqueNames, ids);
id2name     = uniqueNames;

m = numel(Author_wp);
rowIDs = cell(m,1);
for i = 1:m
    names = splitAuthors{i};
    rowIDs{i} = cellfun(@(nm) authorDict(nm), names);
end

[Year_sorted, idx] = sort(Year_wp);
papers = rowIDs(idx);
end

function yearsById = local_eligibilityYearById(id2name, mapObj)
if ~(isa(mapObj,'containers.Map')), error('eligibility map must be containers.Map'); end
yearsById = inf(numel(id2name),1);
for id = 1:numel(id2name)
    nm = normalizePartyName(id2name{id});
    if isKey(mapObj, nm), yearsById(id) = mapObj(nm); end
end
end

function [firstIdx, runLen] = firstIndicesOfGroups(v)
if isempty(v), firstIdx = []; runLen = []; return; end
d = [true; diff(v(:))~=0];
firstIdx = find(d);
nxt = [firstIdx(2:end)-1; numel(v)];
runLen = nxt - firstIdx + 1;
end

function nm = normalizePartyName(nm)
nm = strtrim(nm);
nm = regexprep(nm, '\s+', ' ');
nm = strrep(nm, 'T√ºrkiye', 'Türkiye');
nm = strrep(nm, 'TÃ¼rkiye', 'Türkiye');
nm = strrep(nm, 'T&uuml;rkiye', 'Türkiye');
nm = regexprep(nm, '\bTurkiye\b', 'Türkiye', 'ignorecase');
nm = regexprep(nm, '\bTurkey\b',  'Türkiye', 'ignorecase');

if any(strcmpi(nm, {'USA','US','U.S.','United States of America'})), nm = 'United States'; end
if any(strcmpi(nm, {'UK','U.K.','Great Britain'})),                   nm = 'United Kingdom'; end
if any(strcmpi(nm, {'Russia','USSR','Soviet Union'})),                nm = 'Russian Federation'; end
if any(strcmpi(nm, {'EEC','EU','European Economic Community'})),      nm = 'European Union'; end
if any(strcmpi(nm, {'Republic of Korea','South Korea'})),             nm = 'Korea (ROK)'; end
if strcmpi(nm,'Czech Republic'), nm = 'Czechia'; end
if any(strcmpi(nm, {'CCALMR','Commission for the Conservation of Antarctic Marine Living Resources'}))
    nm = 'CCAMLR';
end
if strcmpi(nm,'Scientific Committee on Antarctic Research'), nm = 'SCAR'; end
end

function out = ifelse(cond, a, b)
if cond, out = a; else, out = b; end
end
